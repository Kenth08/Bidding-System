# Copy this file to .env and fill in your values.
# Never commit backend/.env to GitHub.
# This file documents all environment variables required by the application.

# === Django Configuration ===
# Generate a strong SECRET_KEY using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# === CORS Configuration ===
# List comma-separated URLs that can access this API (no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# === Database Configuration ===
# Option A: Use a full DATABASE_URL value (recommended for Supabase/managed databases)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Option B: Use individual database fields if DATABASE_URL is not set
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_HOST=localhost
# DB_PORT=5432

# === Supabase Configuration ===
# Supabase URL and ANON_KEY (public keys - safe to expose on frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (KEEP SECRET - never expose to frontend or Git)
# Only used server-side for admin operations
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# === Application Settings ===
# Time zone for audit logs and timestamps
TIME_ZONE=Asia/Manila

# === Security Settings ===
# Set to True in production with HTTPS
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# === Logging ===
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
