# Copy this file to .env and fill in your values.
# Never commit backend/.env to GitHub.

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Supabase PostgreSQL
# Option A: Use a full DATABASE_URL value.
DATABASE_URL=postgresql://postgres.govclthxhiaqnnuzanvy:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Option B: Use individual database fields if DATABASE_URL is not set.
DB_NAME=postgres
DB_USER=postgres.govclthxhiaqnnuzanvy
DB_PASSWORD=YOUR_PASSWORD_HERE
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=5432

# Supabase API
SUPABASE_URL=https://govclthxhiaqnnuzanvy.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
